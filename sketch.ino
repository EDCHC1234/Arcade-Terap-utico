// ============================================================
//  Dibuja el bitmap del menú actual en la pantalla
// ============================================================
void mostrarMenu(int indice) {
  display.clearDisplay();
  display.drawBitmap(0, 0, menus[indice], SCREEN_WIDTH, SCREEN_HEIGHT, 1);
  display.display();
}

// ============================================================
//  setup()
// ============================================================
void setup() {
  Serial.begin(115200);

  // I2C en los pines correctos de tu esquema
  Wire.begin(21, 22);  // SDA=21, SCL=22

  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println("Error: pantalla OLED no encontrada");
    for (;;);
  }

  pinMode(JOY_SW, INPUT_PULLUP);
  for(int i=0;i<4;i++){
    pinMode(buttonPins[i], INPUT_PULLUP);
    pinMode(ledPins[i], OUTPUT);
  }
  pinMode(LED_NARANJA, OUTPUT);
  randomSeed(micros());

  // Mostrar el primer menú al arrancar
  mostrarMenu(menuActual);
  Serial.println("NeuroPlay iniciado. Menu: 0");
}

// ============================================================
//  loop()
// ============================================================
void loop() {
  unsigned long ahora = millis();

  // Solo procesar si pasó el tiempo de debounce
  if (ahora - tUltimoMovimiento < DEBOUNCE_MS) return;

  int ver = analogRead(JOY_VER);   // 0–4095

  // ── Joystick ABAJO → siguiente menú ──────────────────────
  // El eje vertical del KY-023: arriba ≈ 0, centro ≈ 2048, abajo ≈ 4095
  if (ver > JOY_CENTRO + JOY_UMBRAL) {
    menuActual = (menuActual + 1) % NUM_MENUS;  // circular: 3→0
    mostrarMenu(menuActual);
    tUltimoMovimiento = ahora;
    Serial.print("Abajo → Menu: ");
    Serial.println(menuActual);
  }

  // ── Joystick ARRIBA → menú anterior ──────────────────────
  else if (ver < JOY_CENTRO - JOY_UMBRAL) {
    menuActual = (menuActual - 1 + NUM_MENUS) % NUM_MENUS;  // circular: 0→3
    mostrarMenu(menuActual);
    tUltimoMovimiento = ahora;
    Serial.print("Arriba → Menu: ");
    Serial.println(menuActual);
  }

  // ── Botón del joystick (SW) → seleccionar juego ──────────
  // Por ahora solo imprime, aquí luego llamas a la función del juego
  if (digitalRead(JOY_SW) == LOW){
    Serial.print("Seleccionado menuActual = ");
    Serial.println(menuActual);

    delay(250);

    switch(menuActual){
      case 0:
        iniciarRescate();
        mostrarMenu(menuActual);
        break;
      case 1:               //Pinta Feliz
        iniciarPintaFeliz();
        mostrarMenu(menuActual);
        break;
      case 2:              // Simón dice
        iniciarSimonDice();
        mostrarMenu(menuActual);
        break;
      case 3:
        iniciarTrazaFacil();
        mostrarMenu(menuActual);
        break;
}

    tUltimoMovimiento = millis();
  }

}
