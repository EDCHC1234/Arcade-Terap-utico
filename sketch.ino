// ── Juega un nivel ────────────────────────────────────────────
bool jugarNivelPinta(const unsigned char* bmp) {
  // 1. Pre-calcular mapa de exterior (solo una vez por nivel)
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(20, 28);
  display.println("Cargando...");
  display.display();

  preCalcularExterior(bmp);
  memset(paintBuffer, 0, sizeof(paintBuffer));

  // 2. Buscar punto de inicio interior automáticamente
  int startX = 64, startY = 32;
  if (!buscarPuntoInicio(bmp, startX, startY)) {
    return true; // bitmap sin interior = nivel trivial
  }

  float cx = startX;
  float cy = startY;

  int totalInterior = contarInterior(bmp);
  if (totalInterior == 0) return true;

  // 80% pintado = nivel completado
  int umbral = (int)(totalInterior * 0.80f);

  const float VEL         = 1.5f;
  const int   ZONA_MUERTA = 600;
  unsigned long tFrame    = 0;

  // Mostrar figura antes de empezar
  display.clearDisplay();
  display.drawBitmap(0, 0, bmp, 128, 64, 1);
  display.display();
  delay(600);

  while (true) {
    // Salir con JOY_SW
    if (digitalRead(JOY_SW) == LOW) { delay(300); return false; }

    // ~30 fps
    unsigned long ahora = millis();
    if (ahora - tFrame < 33) continue;
    tFrame = ahora;

    // Leer joystick
    int rawH = analogRead(JOY_HOR);
    int rawV = analogRead(JOY_VER);
    float dx = 0, dy = 0;
    if (abs(rawH - 2048) > ZONA_MUERTA) dx = (rawH - 2048) / 2048.0f * VEL;
    if (abs(rawV - 2048) > ZONA_MUERTA) dy = (rawV - 2048) / 2048.0f * VEL;

    float nx = constrain(cx + dx, 0, 127);
    float ny = constrain(cy + dy, 0, 63);
    int   ix = (int)nx;
    int   iy = (int)ny;

    // ── NUEVA LÓGICA: pierde solo si llega al EXTERIOR ───────
    // El contorno blanco NO hace perder (no está en exteriorBuffer)
    if (esExterior(ix, iy)) {
      dibujarPinta(bmp, (int)cx, (int)cy);
      animacionGameOverPinta();
      return false;
    }

    // Mover cursor y pintar
    cx = nx;
    cy = ny;
    pintarAreaGruesa(bmp, ix, iy);

    // Verificar completado
    if (contarPintados(bmp) >= umbral) {
      dibujarPinta(bmp, ix, iy);
      return true;
    }

    dibujarPinta(bmp, ix, iy);
  }
}

// ── Función principal Pinta Feliz ─────────────────────────────
void iniciarPintaFeliz() {
  const unsigned char* niveles[3] = {
    epd_bitmap_PintaFeliz_N1,
    epd_bitmap_PintaFeliz_N2,
    epd_bitmap_PintaFeliz_N3
  };

  int nivel = 0;
  while (nivel < 3) {
    // Mostrar figura del nivel
    display.clearDisplay();
    display.drawBitmap(0, 0, niveles[nivel], 128, 64, 1);
    display.display();
    delay(500);

    bool completo = jugarNivelPinta(niveles[nivel]);

    if (completo) {
      if (nivel < 2) { animacionNivelOkPinta(nivel + 1); nivel++; }
      else           { animacionVictoriaPinta(); return; }
    } else {
      return; // game over o JOY_SW → vuelve al menú
    }
  }
}