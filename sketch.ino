// ── LOGICA PARA PINTA FELIZ ─────────────────────────


bool pixelEnBitmap(const unsigned char* bmp, int x, int y) {
  if (x < 0 || x >= 128 || y < 0 || y >= 64) return false;
  int idx = (y * 128 + x) / 8;
  int bit = 7 - ((y * 128 + x) % 8);
  return (pgm_read_byte(&bmp[idx]) >> bit) & 0x01;
}

// ── Buffers en RAM ────────────────────────────────────────────
// exteriorBuffer: 1 bit por pixel, 1 = exterior, 0 = interior o contorno
uint8_t exteriorBuffer[64][16];

// paintBuffer: 1 bit por pixel, 1 = pintado por el jugador
uint8_t paintBuffer[64][16];

// Stack para el flood-fill (máx 8192 posiciones = 16 KB)
// Posición = y * 128 + x  (uint16_t cabe en 0..8191)
static uint16_t ffStack[8192];

// ── Operaciones sobre los buffers ────────────────────────────
void setBit(uint8_t buf[][16], int x, int y) {
  if (x < 0 || x >= 128 || y < 0 || y >= 64) return;
  buf[y][x / 8] |= (0x80 >> (x % 8));
}
bool getBit(uint8_t buf[][16], int x, int y) {
  if (x < 0 || x >= 128 || y < 0 || y >= 64) return false;
  return (buf[y][x / 8] >> (7 - (x % 8))) & 0x01;
}

// ── Flood-fill iterativo desde (sx, sy) ──────────────────────
// Marca en exteriorBuffer todos los pixels negros (no-contorno)
// alcanzables desde (sx,sy) sin cruzar pixels blancos del bitmap.
void floodFillExterior(const unsigned char* bmp, int sx, int sy) {
  if (pixelEnBitmap(bmp, sx, sy)) return; // punto inicial es contorno
  if (getBit(exteriorBuffer, sx, sy))     return; // ya visitado

  int top = 0;
  ffStack[top++] = (uint16_t)(sy * 128 + sx);
  setBit(exteriorBuffer, sx, sy);

  const int8_t dx[4] = {1, -1, 0,  0};
  const int8_t dy[4] = {0,  0, 1, -1};

  while (top > 0) {
    uint16_t pos = ffStack[--top];
    int cx = pos % 128;
    int cy = pos / 128;

    for (int d = 0; d < 4; d++) {
      int nx = cx + dx[d];
      int ny = cy + dy[d];
      if (nx < 0 || nx >= 128 || ny < 0 || ny >= 64) continue;
      if (pixelEnBitmap(bmp, nx, ny))    continue; // contorno = barrera
      if (getBit(exteriorBuffer, nx, ny)) continue; // ya marcado
      setBit(exteriorBuffer, nx, ny);
      if (top < 8191)  // proteger overflow
        ffStack[top++] = (uint16_t)(ny * 128 + nx);
    }
  }
}

// ── Pre-calcular mapa de exterior antes de cada nivel ─────────
// Hace flood-fill desde las 4 esquinas y los bordes para
// asegurar que TODO el exterior quede marcado.
void preCalcularExterior(const unsigned char* bmp) {
  memset(exteriorBuffer, 0, sizeof(exteriorBuffer));

  // Flood desde las 4 esquinas
  floodFillExterior(bmp, 0,   0);
  floodFillExterior(bmp, 127, 0);
  floodFillExterior(bmp, 0,   63);
  floodFillExterior(bmp, 127, 63);

  // Barrer todos los bordes por si alguna esquina es contorno
  for (int x = 0; x < 128; x++) {
    floodFillExterior(bmp, x, 0);
    floodFillExterior(bmp, x, 63);
  }
  for (int y = 0; y < 64; y++) {
    floodFillExterior(bmp, 0,   y);
    floodFillExterior(bmp, 127, y);
  }
}

// ── Verifica si (x,y) es exterior (mapa pre-calculado) ───────
// true  → exterior → pierde si el cursor llega aquí
// false → interior o contorno → puede seguir jugando
bool esExterior(int x, int y) {
  if (x < 0 || x >= 128 || y < 0 || y >= 64) return true;
  return getBit(exteriorBuffer, x, y);
}

// ── Busca automáticamente el punto de inicio interior ─────────
// Escanea la fila central (y=32) y busca el primer pixel negro
// que NO sea exterior (es decir, que sea interior real).
// Si no encuentra en y=32, prueba filas cercanas.
bool buscarPuntoInicio(const unsigned char* bmp, int &outX, int &outY) {
  for (int dy = 0; dy < 32; dy++) {
    for (int signo = 0; signo <= 1; signo++) {
      int y = 32 + (signo == 0 ? dy : -dy);
      if (y < 0 || y >= 64) continue;
      for (int x = 0; x < 128; x++) {
        if (!pixelEnBitmap(bmp, x, y) && !esExterior(x, y)) {
          outX = x;
          outY = y;
          return true;
        }
      }
    }
  }
  return false; // no encontró (bitmap sin interior)
}

// ── Marca pixel como pintado ──────────────────────────────────
void marcarPixel(int x, int y) { setBit(paintBuffer, x, y); }
bool pixelPintado(int x, int y) { return getBit(paintBuffer, x, y); }

// ── Pinta área gruesa 5×5 alrededor del cursor ───────────────
// Solo pinta pixels que son INTERIOR (no contorno, no exterior)
void pintarAreaGruesa(const unsigned char* bmp, int cx, int cy) {
  const int RADIO = 2;
  for (int dy = -RADIO; dy <= RADIO; dy++)
    for (int dx = -RADIO; dx <= RADIO; dx++) {
      int px = cx + dx, py = cy + dy;
      if (!pixelEnBitmap(bmp, px, py) && !esExterior(px, py))
        marcarPixel(px, py);
    }
}

// ── Cuenta pixels interiores totales ─────────────────────────
int contarInterior(const unsigned char* bmp) {
  int total = 0;
  for (int y = 0; y < 64; y++)
    for (int x = 0; x < 128; x++)
      if (!pixelEnBitmap(bmp, x, y) && !esExterior(x, y))
        total++;
  return total;
}

// ── Cuenta pixels interiores ya pintados ─────────────────────
int contarPintados(const unsigned char* bmp) {
  int cnt = 0;
  for (int y = 0; y < 64; y++)
    for (int x = 0; x < 128; x++)
      if (!pixelEnBitmap(bmp, x, y) && !esExterior(x, y) && pixelPintado(x, y))
        cnt++;
  return cnt;
}

// ── Dibuja contorno + pintura + cursor ───────────────────────
void dibujarPinta(const unsigned char* bmp, int cx, int cy) {
  display.clearDisplay();
  display.drawBitmap(0, 0, bmp, 128, 64, 1);
  for (int y = 0; y < 64; y++)
    for (int x = 0; x < 128; x++)
      if (pixelPintado(x, y))
        display.drawPixel(x, y, SSD1306_WHITE);
  // Cursor 3×3
  for (int dy = -1; dy <= 1; dy++)
    for (int dx = -1; dx <= 1; dx++)
      display.drawPixel(cx + dx, cy + dy, SSD1306_WHITE);
  display.display();
}

